"""
POCOmeta Configuration Template
===============================

COPY THIS FILE TO settings.py AND CUSTOMIZE FOR YOUR ENVIRONMENT

This template shows all available settings with explanations.
Copy this file to "settings.py" and modify the values for your setup.

IMPORTANT: After copying and customizing, restart the script for changes to take effect.

REQUIRED SETTINGS TO CHANGE:
1. PAPERLESS_URL - Set to your Paperless server URL
2. PAPERLESS_TOKEN - Set your API token (or use environment variable)
"""

# =============================================================================
# REQUIRED: PAPERLESS SERVER CONNECTION
# =============================================================================

# Your Paperless-ngx server URL (include http:// or https://)
# CHANGE THIS: Replace with your actual server URL
# Examples: 
#   - Local server: "http://localhost:8000"
#   - Remote server: "https://paperless.mydomain.com"
#   - Dockerized: "http://192.168.1.100:8000"
PAPERLESS_URL = "CHANGE_ME_TO_YOUR_PAPERLESS_URL"

# Your Paperless API token (get this from Account Settings > API Tokens)
# CHANGE THIS: Either set this value OR set PAPERLESS_TOKEN environment variable
# For security, using environment variable is recommended
PAPERLESS_TOKEN = "CHANGE_ME_TO_YOUR_API_TOKEN"

# =============================================================================
# DOCUMENT FILTERING
# =============================================================================

# Only process documents that have these tags
# DEFAULT: Process documents tagged "NEW"
INCLUDE_TAGS = ["NEW"]

# Skip documents that already have these tags  
# DEFAULT: No exclusions (empty list)
EXCLUDE_TAGS = []

# =============================================================================
# PROCESSING BEHAVIOR
# =============================================================================

# Maximum number of documents to process in one run
# DEFAULT: No limit (None)
DOCUMENT_LIMIT = None

# Only process specific document ID (for testing specific documents)
# DEFAULT: Process all matching documents (None)
DOCUMENT_ID_FILTER = None

# Set to True to simulate processing without making changes
# DEFAULT: False (make real changes)
DRY_RUN_MODE = False

# Enable detailed output showing processing steps
# DEFAULT: False
VERBOSE_OUTPUT = False

# Enable debug logging for troubleshooting
# DEFAULT: False
DEBUG_MODE = False

# =============================================================================
# RULE CONFIGURATION
# =============================================================================

# Directory containing your YAML rule files
# DEFAULT: "rules" (rules folder in same directory)
RULES_DIRECTORY = "rules"

# Minimum score for a rule to be considered a match (0-100)
# DEFAULT: 70 (higher = stricter matching)
RULE_EVALUATION_THRESHOLD = 70

# =============================================================================
# CONFIDENCE SCORING (POCO)
# =============================================================================

# Enable POCO confidence scoring system
# DEFAULT: True
POCO_SCORING_ENABLED = True

# Minimum POCO confidence score to apply metadata (0-100)
# DEFAULT: 60 (documents below this get tagged but no metadata applied)
POCO_THRESHOLD = 60

# Tag to apply for documents processed with low confidence
# DEFAULT: "POCO"
POCO_TAG_NAME = "POCO"

# Weights for different metadata fields in POCO scoring (must total 100)
# DEFAULT: Balanced weights across all fields
POCO_FIELD_WEIGHTS = {
    "title": 20,
    "correspondent": 25,
    "document_type": 15,
    "tags": 10,
    "created": 15,
    "custom_fields": 15
}

# =============================================================================
# METADATA PROCESSING
# =============================================================================

# Apply metadata updates to documents
# DEFAULT: True (set False for permanent dry-run mode)
APPLY_METADATA_UPDATES = True

# Automatically create missing items in Paperless
# DEFAULT: All True (create missing items automatically)
CREATE_MISSING_TAGS = True
CREATE_MISSING_CORRESPONDENTS = True
CREATE_MISSING_DOCUMENT_TYPES = True
CREATE_MISSING_CUSTOM_FIELDS = True

# =============================================================================
# OUTPUT AND LOGGING
# =============================================================================

# Enable file logging
# DEFAULT: True
LOG_TO_FILE = True
LOG_FILE_PATH = "log.txt"

# Enable colored console output
# DEFAULT: True
COLORED_OUTPUT = True

# Show processing statistics summary
# DEFAULT: True
SUMMARY_STATISTICS = True

# =============================================================================
# ADVANCED FEATURES (Usually don't need to change these)
# =============================================================================

# API and Performance Settings
API_REQUEST_TIMEOUT = 30
MAX_CONCURRENT_REQUESTS = 5
CONTENT_CACHE_SIZE = 100

# Rule Development Features (useful for creating new rules)
SHOW_RULE_EVALUATIONS = True
SHOW_PATTERN_MATCHING = True
SHOW_METADATA_COMPARISON = True
SHOW_CONFIDENCE_SCORING = True

# Document Content Processing
CONTENT_EXTRACTION_RANGE = "0-2000"
FILENAME_PATTERN_MATCHING = True
CASE_SENSITIVE_MATCHING = False

# Tag Management
REMOVE_PROCESSING_TAGS = True
ADD_CONFIDENCE_TAGS = True
CONFIDENCE_TAG_PREFIX = "POCO-"

# Custom Field Configuration
DEFAULT_CUSTOM_FIELDS = {
    "Document Category": "text",
    "Processing Confidence": "integer", 
    "Rule Applied": "text"
}

# Error Handling
CONTINUE_ON_ERRORS = True
MAX_RETRY_ATTEMPTS = 3
SKIP_DUPLICATE_PROCESSING = True

# Document Type Mapping (maps rule document types to Paperless document types)
DOCUMENT_TYPE_ALIASES = {
    "bank_statement": "Bank Statement",
    "invoice": "Invoice", 
    "receipt": "Receipt",
    "contract": "Contract"
}

# =============================================================================
# CONFIGURATION HELPER FUNCTIONS
# =============================================================================

def get_settings():
    """Return all settings as a dictionary"""
    import sys
    current_module = sys.modules[__name__]
    
    # Get all uppercase variables (settings)
    settings = {
        key: getattr(current_module, key) for key in dir(current_module)
        if key.isupper() and not key.startswith('_')
    }
    
    return settings

def validate_required_settings():
    """
    Validate that required settings are provided.
    Returns tuple (is_valid, error_messages)
    """
    errors = []
    
    # Check for placeholder values that need to be changed
    if not PAPERLESS_URL or PAPERLESS_URL == "CHANGE_ME_TO_YOUR_PAPERLESS_URL":
        errors.append("PAPERLESS_URL must be changed from the template value to your actual Paperless server URL")
        errors.append("Example: PAPERLESS_URL = 'http://localhost:8000'")
    
    if not PAPERLESS_TOKEN or PAPERLESS_TOKEN == "CHANGE_ME_TO_YOUR_API_TOKEN":
        import os
        if not os.getenv('PAPERLESS_TOKEN'):
            errors.append("PAPERLESS_TOKEN must be set either in settings.py or as environment variable")
            errors.append("Get your token from: Paperless > Account Settings > API Tokens")
    
    if not INCLUDE_TAGS:
        errors.append("INCLUDE_TAGS must specify at least one tag to filter documents")
    
    if not RULES_DIRECTORY:
        errors.append("RULES_DIRECTORY must be specified")
    
    return len(errors) == 0, errors

# =============================================================================
# QUICK SETUP CHECKLIST
# =============================================================================
"""
QUICK SETUP CHECKLIST:

□ 1. Copy this file to 'settings.py'
□ 2. Change PAPERLESS_URL to your server URL
□ 3. Change PAPERLESS_TOKEN to your API token (or set environment variable)
□ 4. Verify INCLUDE_TAGS matches your document tagging (default: ["NEW"])
□ 5. Test with: python3 main.py --dry-run --verbose --limit 1

ADVANCED SETUP (Optional):
□ Adjust RULE_EVALUATION_THRESHOLD if rules are too strict/loose
□ Modify POCO_THRESHOLD for confidence requirements
□ Customize POCO_FIELD_WEIGHTS for your metadata priorities
□ Set up custom DOCUMENT_TYPE_ALIASES for your document types

TROUBLESHOOTING:
- Run with --debug flag to see detailed processing information
- Use --show-content ID to view document content for rule development
- Use --id-only to list available document IDs
- Check log.txt file for processing history
"""