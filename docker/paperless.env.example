# Paperless-ngx Configuration with POCOmeta Integration
# Copy this file to 'paperless.env' and customize the values

# =============================================================================
# REQUIRED: Basic Paperless Configuration
# =============================================================================

# Secret key for Django (generate with: openssl rand -base64 32)
PAPERLESS_SECRET_KEY=change-me-to-a-random-string

# URL where Paperless will be accessible
PAPERLESS_URL=http://localhost:8000

# Admin user (created on first run)
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=admin

# Time zone
PAPERLESS_TIME_ZONE=UTC

# =============================================================================
# REQUIRED: POCOmeta Integration
# =============================================================================

# Post-consumption script (enables POCOmeta)
PAPERLESS_POST_CONSUME_SCRIPT=/usr/src/paperless/scripts/post_consume/poco_wrapper.sh

# POCOmeta behavior settings
POCO_DRY_RUN=false          # Set to 'true' to simulate without making changes
POCO_VERBOSE=false          # Set to 'true' for detailed logging
POCO_MAX_DOCUMENTS=0        # Limit documents processed (0 = no limit)

# =============================================================================
# API Configuration (Auto-configured for Docker)
# =============================================================================

# API token for POCOmeta (will be auto-generated)
# Leave blank - POCOmeta will use internal Docker communication
PAPERLESS_TOKEN=

# =============================================================================
# OPTIONAL: Document Processing
# =============================================================================

# Document consumption settings
PAPERLESS_CONSUMER_POLLING=60
PAPERLESS_CONSUMER_RECURSIVE=true
PAPERLESS_CONSUMER_SUBDIRS_AS_TAGS=true

# OCR settings
PAPERLESS_OCR_LANGUAGE=eng
PAPERLESS_OCR_MODE=redo

# =============================================================================
# OPTIONAL: Storage and Performance
# =============================================================================

# File naming
PAPERLESS_FILENAME_FORMAT={created_year}/{correspondent}/{title}

# Database settings (PostgreSQL is configured in docker-compose.yml)
PAPERLESS_DBHOST=db
PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=paperless
PAPERLESS_DBPASS=paperless

# Redis settings
PAPERLESS_REDIS=redis://broker:6379

# =============================================================================
# OPTIONAL: Security and Access
# =============================================================================

# Allowed hosts (add your domain/IP)
PAPERLESS_ALLOWED_HOSTS=localhost,127.0.0.1

# CORS settings (if using API from other domains)
PAPERLESS_CORS_ALLOWED_HOSTS=http://localhost:8000

# =============================================================================
# OPTIONAL: Tika and Gotenberg (Document Processing)
# =============================================================================

PAPERLESS_TIKA_ENABLED=1
PAPERLESS_TIKA_ENDPOINT=http://tika:9998
PAPERLESS_TIKA_GOTENBERG_ENDPOINT=http://gotenberg:3000

# =============================================================================
# POCOmeta Advanced Settings
# =============================================================================

# Rules directory (inside container)
POCO_RULES_DIR=/usr/src/paperless/scripts/post_consume/POCOmeta/rules

# Logging level (DEBUG, INFO, WARNING, ERROR)
POCO_LOG_LEVEL=INFO

# Tag settings
POCO_INCLUDE_TAGS=NEW               # Process documents with these tags
POCO_EXCLUDE_TAGS=                  # Skip documents with these tags
POCO_SUCCESS_TAG=POCO               # Tag added on successful processing
POCO_FAILURE_TAG=POCO_FAILED        # Tag added on processing failure

# Confidence thresholds
POCO_MIN_SCORE=70                   # Minimum confidence score to apply metadata
POCO_RULE_THRESHOLD=50              # Minimum rule match score