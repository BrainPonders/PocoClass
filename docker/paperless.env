# ------------------------------------------------------------------------
# eRJe 15-05-2025
# Environment file for Paperless Docker stack
# ------------------------------------------------------------------------

# -------------------------------------------------------
# System User and Group Configuration
# -------------------------------------------------------
# These values map to the 'paperless' Linux user (UID 1018)
# and group (GID 1018), ensuring correct file ownership
PUID=1018
PGID=1018

# -------------------------------------------------------
# Paperless-ngx Core Configuration
# -------------------------------------------------------
# Set your local timezone (affects OCR timestamps, logs, etc.)
PAPERLESS_TIME_ZONE=Europe/Berlin

# Languages to support for OCR (space-separated, Tesseract format)
PAPERLESS_OCR_LANGUAGES=eng nld fra deu
PAPERLESS_OCR_LANGUAGE=eng+nld+fra+deu

# Django secret key (change only if you re-deploy or lose DB)
PAPERLESS_SECRET_KEY='wKrk17cW_i0O$39c8OgI:iv7aj(}lGh!.IFOhf^r%F<k[]Sp~>)8{H)MgGjr6Lh`'

# -------------------------------------------------------
# Import/Export Behavior
# -------------------------------------------------------
# Set to true to enable scanning subfolders in /consume
PAPERLESS_CONSUMER_RECURSIVE=True

# -------------------------------------------------------
# Network and Access Configuration
# -------------------------------------------------------
# External-facing URL used in QR codes, emails, etc.
# PAPERLESS_URL=https://paperless.erje.nl
PAPERLESS_URL=http://localhost:8000

# Reverse proxy IPs you trust (Caddy, Nginx, etc.)
PAPERLESS_TRUSTED_PROXIES=192.168.2.2

# -------------------------------------------------------
# POCOmeta Configuration
# -------------------------------------------------------
# Admin API token for POCOmeta to access Paperless API
PAPERLESS_API_TOKEN=50d79dae1ed0450dbbd24b43a459a3b451001911

# POCOmeta document filtering
FILTER_TAG_INCLUDE=NEW
FILTER_TAG_EXCLUDE=POCO
COMPLETION_TAG=POCO

# POCOmeta processing settings
POCO_MAX_DOCUMENTS=0
POCO_DRY_RUN=false
POCO_VERBOSE=false

# -------------------------------------------------------
# AI COMPONENTS - COMMENTED OUT (Remove if not needed)
# -------------------------------------------------------
# Paperless-AI Configuration: SET IN  /paperless-ai/data/.env
# PAPERLESS_AI_PORT=3000
# PAPERLESS_AI_INITIAL_SETUP=yes
# PAPERLESS_API_URL=http://webserver:8000/api
# AI_PROVIDER=custom
# OLLAMA_API_URL=http://ollama:11434
# OLLAMA_MODEL=deepseek-coder
# SCAN_INTERVAL=*/30 * * * *
# PROCESS_PREDEFINED_DOCUMENTS=yes
# TAGS=pre-process
# ADD_AI_PROCESSED_TAG=no
# AI_PROCESSED_TAG_NAME=ai-processed
# USE_PROMPT_TAGS=no
# USE_EXISTING_DATA=no
# SYSTEM_PROMPT_FILE=/config/system_prompt.txt
