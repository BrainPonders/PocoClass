services:
  pococlass:
    image: "${POCOCLASS_IMAGE}"
    container_name: pococlass-dev
    restart: unless-stopped

    ports:
      - "${POCOCLASS_PORT:-5000}:5000"

    environment:
      POCOCLASS_SECRET_KEY: "${POCOCLASS_SECRET_KEY:-}"
      PAPERLESS_URL: "${PAPERLESS_URL}"
      GUNICORN_WORKERS: "${GUNICORN_WORKERS:-3}"
      GUNICORN_THREADS: "${GUNICORN_THREADS:-2}"
      GUNICORN_TIMEOUT: "${GUNICORN_TIMEOUT:-120}"

    volumes:
      - "${DEV_DATA_DIR}:/app/data"
      - "${DEV_RULES_DIR}:/app/rules"

    healthcheck:
      test: ["CMD-SHELL", "python3 -c \"import urllib.request; urllib.request.urlopen('http://localhost:5000/api/health', timeout=5)\" || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 20s

    networks:
      - paperless

networks:
  paperless:
    name: "${PAPERLESS_NETWORK_NAME:-paperless_default}"
    external: ${PAPERLESS_NETWORK_EXTERNAL:-true}
