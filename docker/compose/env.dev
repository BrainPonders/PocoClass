# PocoClass developer environment template.
# Runtime location used by scripts/Maintainer/dev-rebuild.sh:
#   ${HOME}/pococlass-dev/.env by default

# Set a valid Fernet key before first run:
# python3 -c "import os, base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
POCOCLASS_SECRET_KEY=

# Image used by docker-compose.dev.yml.
# scripts/Maintainer/dev-rebuild.sh updates this value in runtime .env.
POCOCLASS_IMAGE=pococlass:dev-latest

# Host port to expose PocoClass UI/API
POCOCLASS_PORT=5000

# Paperless URL from inside Docker network
PAPERLESS_URL=http://paperless-ngx:8000

# Shared Docker network with Paperless
PAPERLESS_NETWORK_NAME=paperless_default
PAPERLESS_NETWORK_EXTERNAL=true

# Persistent dev volumes
DEV_DATA_DIR=
DEV_RULES_DIR=

# Optional Gunicorn tuning
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
