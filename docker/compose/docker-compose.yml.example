# Docker Compose example for deploying PocoClass next to a Paperless-ngx stack
# using bridge networking.
# PAPERLESS_URL must point to the Docker-internal Paperless URL.
# Supported presets live in `.env.example`.

services:
  pococlass:
    image: ${POCOCLASS_IMAGE:-ghcr.io/brainponders/pococlass:latest}
    container_name: pococlass
    restart: unless-stopped

    ports:
      # Change the host port if 5000 is already in use
      - "5000:5000"

    env_file:
      - .env

    volumes:
      # Persistent PocoClass data
      - ./data:/app/data

      # YAML rules created by the user
      - ./rules:/app/rules

    healthcheck:
      test: ["CMD-SHELL", "python3 -c \"import urllib.request; urllib.request.urlopen('http://localhost:5000/api/health', timeout=5)\" || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 20s

    networks:
      - paperless

networks:
  paperless:
    # Network name comes from .env so the same compose can support official and 11notes
    name: ${PAPERLESS_NETWORK_NAME:-paperless_default}
    external: true
