# eRJe 2026-03-09: PocoClass
# -----------------------------------------------------------------------------
# Environment file for deploying PocoClass next to a Paperless-ngx Docker
# stack using bridge networking.
#
# Docs:
# https://github.com/BrainPonders/PocoClass
#
# Notes (this deployment):
# - PAPERLESS_URL must be the Docker-internal Paperless URL.
# - Official Paperless defaults are active below.
# - 11notes Paperless values are provided as commented presets.
# - Generate POCOCLASS_SECRET_KEY once and keep it stable.
#
# -----------------------------------------------------------------------------
# History:
# 2026-03-09 | eRJe | Simplified shared env template with official + 11notes presets
# -----------------------------------------------------------------------------

# REQUIRED: Fernet-compatible secret key for PocoClass sessions and encryption
# Generate with:
# python3 -c "import os, base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
POCOCLASS_SECRET_KEY=

# REQUIRED: Docker-internal Paperless URL
# Official Paperless default service name: webserver
PAPERLESS_URL=http://webserver:8000

# OPTIONAL: Override image tag for testing or pinning releases
POCOCLASS_IMAGE=ghcr.io/BrainPonders/pococlass:latest

# OPTIONAL: Shared Docker network name
# Official Paperless default network name:
PAPERLESS_NETWORK_NAME=paperless_default

# 11notes preset:
# Uncomment these and disable the two official values above if you run the
# 11notes Paperless stack.
# PAPERLESS_URL=http://paperless-ngx:8000
# PAPERLESS_NETWORK_NAME=<your_11notes_network_name>
