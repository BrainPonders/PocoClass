# PocoClass Environment Configuration
#
# Copy this file to your deploy root as .env
# The installer does this automatically on first install.

# Secret key for session encryption (required at runtime, do not share)
# Runtime-only: not used during docker build.
# Fernet format required: 32 bytes URL-safe base64-encoded key
# Generate with: python3 -c "import os, base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
POCOCLASS_SECRET_KEY=

# Optional image reference (useful for testing/release tags)
# Default in compose is: pococlass:latest
# Example: POCOCLASS_IMAGE=pococlass:build-20260216-abc123
POCOCLASS_IMAGE=pococlass:latest

# Paperless URL (required)
# You must set this value based on the compose mode you selected.
# Choose exactly one style:
# - docker-compose.bridge.yml: use Docker-internal hostname
#   - Official paperless-ngx: http://paperless-webserver:8000
#   - 11notes paperless-ngx:  http://paperless-ngx:8000
# - docker-compose.host.yml: use the same URL you use in your browser UI
#   - Example: https://paperless.example.com
PAPERLESS_URL=

# Optional metadata from installer
PAPERLESS_PROFILE=official
PAPERLESS_CONTAINER_NAME=paperless-webserver

# Docker network shared with Paperless-ngx (bridge mode only)
# Ignored by host mode compose
PAPERLESS_NETWORK_NAME=paperless_default
PAPERLESS_NETWORK_EXTERNAL=true
