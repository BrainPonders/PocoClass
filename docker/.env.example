# PocoClass Environment Configuration
#
# Copy this file to your deploy root and rename to .env
# The install script does this automatically on first install.

# Secret key for session encryption (required, do not share)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
POCOCLASS_SECRET_KEY=

# Paperless-ngx URL as seen from inside the Docker network
# This is NOT your browser URL - it is the internal Docker hostname
# Tip: run "docker ps" to find your Paperless container name
PAPERLESS_URL=http://paperless-ngx:8000
