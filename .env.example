# PocoClass Environment Variables Template
# Copy this file to .env and fill in your values
# 
# IMPORTANT: .env is in .gitignore - NEVER commit secrets to version control!

# =============================================================================
# REQUIRED: Encryption Key
# =============================================================================
# Generate with: python3 generate_secret_key.py
# This key encrypts Paperless API tokens in the database
# CRITICAL: Keep this key consistent - changing it invalidates all user sessions
POCOCLASS_SECRET_KEY=your_generated_key_here

# =============================================================================
# OPTIONAL: Paperless-ngx Configuration
# =============================================================================
# These are optional - PocoClass can be configured via the Web UI instead
# Useful for automated deployments or background processing

# Your Paperless-ngx instance URL
PAPERLESS_URL=http://localhost:8000

# Paperless API token for background processing (optional)
# Get this from Paperless: Settings → API → Generate Token
# Used ONLY for automated background processing without user login
PAPERLESS_TOKEN=your_paperless_api_token_here

# =============================================================================
# DATABASE (Auto-configured by Replit)
# =============================================================================
# These are automatically set by Replit if using the built-in database
# For standalone deployments, configure your PostgreSQL connection:
# DATABASE_URL=postgresql://user:password@host:5432/database
